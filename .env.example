# 競馬予想API 環境変数テンプレート

# 環境設定
ENV=production  # development, staging, production
LOG_LEVEL=info  # debug, info, warning, error

# APIサーバー設定
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# CORS設定（カンマ区切り）
ALLOWED_ORIGINS=https://keiba-intelligence.netlify.app,http://localhost:4321

# データベース（将来追加の場合）
# DATABASE_URL=postgresql://user:password@localhost:5432/keiba_ai

# モデルパス
MODEL_PATH=models/random_forest_model.pkl

# レート制限
RATE_LIMIT_PER_MINUTE=60

# モニタリング（オプション）
# SENTRY_DSN=https://xxx@sentry.io/xxx
# NEW_RELIC_LICENSE_KEY=xxx
